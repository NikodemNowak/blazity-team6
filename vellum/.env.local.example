# Required for the Chat feature (repo ingestion + Claude)
ANTHROPIC_API_KEY=sk-ant-...
# Strongly recommended: a fine-grained GitHub PAT (Contents: Read-only).
# Without it, ingestion is unauthenticated (60 req/h) and large repos load
# only partially; private repos require it.
GITHUB_TOKEN=github_pat_...

# Optional — AI provider + per-task models (defaults target Claude).
# AI_PROVIDER=anthropic            # anthropic | openai | google
# MODEL_CHAT=claude-sonnet-4-6
# MAX_TOKENS_CHAT=4000
