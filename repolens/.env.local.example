# Required for the Chat feature (Claude)
ANTHROPIC_API_KEY=sk-ant-...

# --- GitHub access: two options ---

# Option A (simplest): a fine-grained PAT (Contents: Read-only), scoped to the
# repos you want. Without any token, ingestion is unauthenticated (60 req/h) and
# large repos load only partially.
GITHUB_TOKEN=

# Option B (best, self-serve): a GitHub App so users click "Connect GitHub" and
# pick repos. Register an App (see README/steps), then set:
GITHUB_APP_SLUG=
GITHUB_APP_CLIENT_ID=
# Base64 of the App's private-key .pem (recommended — avoids newline issues):
#   base64 -w0 your-app.private-key.pem   (Linux)  /  certutil -encode (Windows)
GITHUB_APP_PRIVATE_KEY_BASE64=
# Random secret used to sign the installation cookie (any long random string):
GITHUB_COOKIE_SECRET=

# Public base URL of the deployed app. REQUIRED behind a proxy/tunnel
# (e.g. Cloudflare → localhost) so GitHub-connect redirects target the public
# domain, not the internal address. Leave unset for plain localhost dev.
# APP_BASE_URL=https://repolens.nikodem.monster

# Optional — AI provider + per-task models (defaults target Claude).
# AI_PROVIDER=anthropic            # anthropic | openai | google
# MODEL_CHAT=claude-sonnet-4-6
# MAX_TOKENS_CHAT=4000
